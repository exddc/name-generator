# --- Required secrets ---
GROQ_API_KEY=groq_api_key
API_JWT_SECRET=api_jwt_secret
BETTER_AUTH_SECRET=better_auth_secret
RESEND_API_KEY=resend_api_key
RESEND_FROM_EMAIL=resend_from_email

# --- URLs ---
NEXT_PUBLIC_API_URL=http://localhost:8000
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
CORS_ALLOW_ORIGINS=http://localhost:3000

# --- Optional overrides ---
WORKER_REPLICAS=1
API_JWT_ISSUER=domain-generator-web
API_JWT_AUDIENCE=domain-generator-api
API_JWT_ALGORITHM=HS256
API_JWT_TTL_SECONDS=300
API_JWT_LEEWAY_SECONDS=10
REDIS_URL=redis://redis:6379/0
RQ_QUEUE=domain_checks
RQ_JOB_TIMEOUT_SECONDS=30
DOMAIN_CHECKER_DNS_TIMEOUT=3.0
WEB_PORT=3000
API_PORT=8000
POSTGRES_HOST_PORT=5432
REDIS_PORT=6379
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=domain_generator
DB_DRIVER=asyncpg
GROQ_MODEL=openai/gpt-oss-20b
GROQ_MODEL_REASONING_EFFORT=low
GROQ_MODEL_STREAM=false
GROQ_MODEL_TEMPERATURE=0.6
GROQ_MODEL_MAX_COMPLETION_TOKENS=4096
GROQ_MODEL_TOP_P=0.95
GROQ_MODEL_INPUT_COST_PER_MILLION=0.075
GROQ_MODEL_CACHED_INPUT_COST_PER_MILLION=0.0375
GROQ_MODEL_OUTPUT_COST_PER_MILLION=0.30
GROQ_CREATIVE_MODEL=openai/gpt-oss-120b
GROQ_CREATIVE_MODEL_REASONING_EFFORT=low
GROQ_CREATIVE_MODEL_STREAM=false
GROQ_CREATIVE_MODEL_TEMPERATURE=0.6
GROQ_CREATIVE_MODEL_MAX_COMPLETION_TOKENS=4096
GROQ_CREATIVE_MODEL_TOP_P=0.95
GROQ_CREATIVE_MODEL_INPUT_COST_PER_MILLION=0.15
GROQ_CREATIVE_MODEL_CACHED_INPUT_COST_PER_MILLION=0.075
GROQ_CREATIVE_MODEL_OUTPUT_COST_PER_MILLION=0.60
# Fail closed on 120B errors by default. Set true only for an explicit 20B fallback.
GROQ_CREATIVE_FALLBACK_TO_DEFAULT=false
# Re-probe an unavailable 120B model without restarting the API.
GROQ_CREATIVE_REVALIDATION_SECONDS=30
GROQ_MODEL_REQUEST_TIMEOUT_SECONDS=15
GROQ_VALIDATE_MODEL_ON_STARTUP=true
MAX_SUGGESTIONS_RETRIES=5
GENERATION_QUOTA_WINDOW_SECONDS=3600
GENERATION_QUOTA_ANONYMOUS=5
GENERATION_QUOTA_AUTHENTICATED=50
GENERATION_QUOTA_ANONYMOUS_NETWORK=20
REDIS_CONNECT_TIMEOUT_SECONDS=0.5
REDIS_SOCKET_TIMEOUT_SECONDS=1.0
